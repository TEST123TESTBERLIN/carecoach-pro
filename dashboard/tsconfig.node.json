{
  "compilerOptions": {
    "composite": true,
    // Emit-Artefakte des Config-Projekts in einen Temp-Ordner, nicht ins Repo
    "outDir": "./node_modules/.tmp/tsconfig.node",
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "strict": true
  },
  "include": ["vite.config.ts"]
}
